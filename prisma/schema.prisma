generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================
// AUTH: Users
// =============================================

enum ErpRole {
  admin      // Full ERP access, user management
  manager    // CRUD products, counterparties, warehouses, pricing
  accountant // Pricing and documents write, rest read
  viewer     // Read-only
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // bcrypt hashed
  email     String?  @unique
  role      ErpRole  @default(viewer)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

// =============================================
// ERP: Enums
// =============================================

enum DocumentStatus {
  draft
  confirmed
  cancelled
}

enum DocumentType {
  // Stock operations
  stock_receipt
  write_off
  stock_transfer
  inventory_count
  // Purchases
  purchase_order
  incoming_shipment
  supplier_return
  // Sales
  sales_order
  outgoing_shipment
  customer_return
  // Finance
  incoming_payment
  outgoing_payment
}

enum PaymentType {
  cash
  bank_transfer
  card
}

enum CounterpartyType {
  customer
  supplier
  both
}

// =============================================
// ERP: Reference Data
// =============================================

model Unit {
  id        String   @id @default(cuid())
  name      String
  shortName String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model ProductCategory {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   ProductCategory?  @relation("ProductCategoryTree", fields: [parentId], references: [id])
  children ProductCategory[] @relation("ProductCategoryTree")
  products Product[]

  @@index([parentId, order])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  sku         String?  @unique
  barcode     String?  @unique
  description String?
  unitId      String
  categoryId  String?
  imageUrl    String?
  imageUrls   Json?    @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // SEO fields (for future e-commerce)
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  slug           String?  @unique

  // E-commerce publishing
  publishedToStore Boolean @default(false)

  // Variant hierarchy (for e-commerce catalog grouping)
  masterProductId  String?
  isMainInGroup    Boolean  @default(false)
  variantGroupName String?

  unit     Unit              @relation(fields: [unitId], references: [id])
  category ProductCategory?  @relation(fields: [categoryId], references: [id])

  // Self-reference for variant hierarchy
  masterProduct Product?  @relation("ProductMasterVariants", fields: [masterProductId], references: [id])
  childVariants Product[] @relation("ProductMasterVariants")

  stockRecords      StockRecord[]
  documentItems     DocumentItem[]
  purchasePrices    PurchasePrice[]
  salePrices        SalePrice[]
  customFields      ProductCustomField[]
  variants          ProductVariant[]
  discounts         ProductDiscount[]
  variantLinksFrom  ProductVariantLink[] @relation("VariantLinksFrom")
  variantLinksTo    ProductVariantLink[] @relation("VariantLinksTo")

  // E-commerce relations
  cartItems         CartItem[]
  orderItems        OrderItem[]
  reviews           Review[]
  favorites         Favorite[]

  @@index([categoryId])
  @@index([isActive])
  @@index([name])
  @@index([slug])
  @@index([masterProductId])
  @@index([variantGroupName])
}

// =============================================
// ERP: Product Custom Fields (characteristics)
// =============================================

model CustomFieldDefinition {
  id        String   @id @default(cuid())
  name      String               // "Цвет", "Материал", "Страна производства"
  fieldType String   @default("text")  // "text", "number", "select", "boolean"
  options   String?              // JSON array for select type: ["Красный","Синий","Зелёный"]
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  values ProductCustomField[]

  @@index([isActive, order])
}

model ProductCustomField {
  id           String @id @default(cuid())
  productId    String
  definitionId String
  value        String  // stored as string, parsed by fieldType

  product    Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  definition CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@unique([productId, definitionId])
  @@index([definitionId])
}

// =============================================
// ERP: Product Variants (modifications)
// =============================================

model VariantType {
  id        String   @id @default(cuid())
  name      String               // "Размер", "Вес", "Цвет"
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  options VariantOption[]

  @@index([isActive, order])
}

model VariantOption {
  id            String @id @default(cuid())
  variantTypeId String
  value         String  // "S", "M", "L", "XL" or "100г", "200г", "500г"
  order         Int    @default(0)

  variantType VariantType      @relation(fields: [variantTypeId], references: [id], onDelete: Cascade)
  variants    ProductVariant[]

  @@index([variantTypeId, order])
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  optionId  String
  sku       String?  @unique  // variant-specific SKU override
  barcode   String?  @unique
  priceAdjustment Float @default(0)  // +/- from base price
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  option  VariantOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  // E-commerce relations
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@unique([productId, optionId])
  @@index([productId])
}

// =============================================
// ERP: Discount System
// =============================================

enum DiscountType {
  percentage  // e.g. 10% off
  fixed       // e.g. 500 RUB off
}

model ProductDiscount {
  id          String       @id @default(cuid())
  productId   String
  name        String               // "Летняя распродажа", "Скидка 10%"
  type        DiscountType
  value       Float                // 10 for 10%, or 500 for 500 RUB
  validFrom   DateTime     @default(now())
  validTo     DateTime?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, isActive, validFrom])
}

// SKU auto-generation counter
model SkuCounter {
  id         String @id @default(cuid())
  prefix     String @unique @default("SKU")
  lastNumber Int    @default(0)
}

// =============================================
// ERP: Product Variant Links (product grouping for website)
// =============================================

model ProductVariantLink {
  id              String   @id @default(cuid())
  productId       String
  linkedProductId String
  groupName       String               // "Цвет", "Размер" - variant group name
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  product       Product @relation("VariantLinksFrom", fields: [productId], references: [id], onDelete: Cascade)
  linkedProduct Product @relation("VariantLinksTo", fields: [linkedProductId], references: [id], onDelete: Cascade)

  @@unique([productId, linkedProductId])
  @@index([productId])
}

// =============================================
// ERP: Counterparties
// =============================================

model Counterparty {
  id            String           @id @default(cuid())
  type          CounterpartyType @default(customer)
  name          String
  legalName     String?
  inn           String?          @unique
  kpp           String?
  bankAccount   String?
  bankName      String?
  bik           String?
  address       String?
  phone         String?
  email         String?
  contactPerson String?
  notes         String?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  interactions   CounterpartyInteraction[]
  purchasePrices PurchasePrice[]
  documents      Document[]
  balance        CounterpartyBalance?
  payments       Payment[]

  @@index([type])
  @@index([isActive])
  @@index([name])
}

model CounterpartyInteraction {
  id             String   @id @default(cuid())
  counterpartyId String
  type           String   // "call", "email", "meeting", "note"
  subject        String?
  description    String?
  createdBy      String?
  createdAt      DateTime @default(now())

  counterparty Counterparty @relation(fields: [counterpartyId], references: [id], onDelete: Cascade)

  @@index([counterpartyId, createdAt])
}

model CounterpartyBalance {
  id             String   @id @default(cuid())
  counterpartyId String   @unique
  balanceRub     Float    @default(0)
  lastUpdatedAt  DateTime @updatedAt

  counterparty Counterparty @relation(fields: [counterpartyId], references: [id], onDelete: Cascade)
}

// =============================================
// ERP: Warehouses & Stock
// =============================================

model Warehouse {
  id              String   @id @default(cuid())
  name            String
  address         String?
  responsibleName String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  stockRecords      StockRecord[]
  documents         Document[]  @relation("WarehouseDocuments")
  incomingTransfers Document[]  @relation("TargetWarehouseDocuments")

  @@index([isActive])
}

model StockRecord {
  id             String   @id @default(cuid())
  warehouseId    String
  productId      String
  quantity       Float    @default(0)
  averageCost    Float    @default(0) // Средняя скользящая себестоимость
  totalCostValue Float    @default(0) // quantity * averageCost
  updatedAt      DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId])
  @@index([productId])
}

// =============================================
// ERP: Documents (core engine)
// =============================================

model DocumentCounter {
  id         String @id @default(cuid())
  prefix     String @unique
  lastNumber Int    @default(0)
}

model Document {
  id                String         @id @default(cuid())
  number            String         @unique
  type              DocumentType
  status            DocumentStatus @default(draft)
  date              DateTime       @default(now())

  warehouseId       String?
  warehouse         Warehouse?     @relation("WarehouseDocuments", fields: [warehouseId], references: [id])

  targetWarehouseId String?
  targetWarehouse   Warehouse?     @relation("TargetWarehouseDocuments", fields: [targetWarehouseId], references: [id])

  counterpartyId    String?
  counterparty      Counterparty?  @relation(fields: [counterpartyId], references: [id])

  totalAmount       Float          @default(0)
  currency          String         @default("RUB")
  paymentType       PaymentType?

  linkedDocumentId  String?
  linkedDocument    Document?      @relation("LinkedDocuments", fields: [linkedDocumentId], references: [id])
  linkedFrom        Document[]     @relation("LinkedDocuments")

  description       String?
  notes             String?
  createdBy         String?
  confirmedAt       DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  items             DocumentItem[]

  // E-commerce relation
  ecommerceOrder    Order?
  payments          Payment[]

  @@index([type, status, date])
  @@index([warehouseId, date])
  @@index([counterpartyId, date])
  @@index([number])
}

model DocumentItem {
  id          String   @id @default(cuid())
  documentId  String
  productId   String
  quantity    Float
  price       Float    @default(0)
  total       Float    @default(0)

  expectedQty Float?
  actualQty   Float?
  difference  Float?

  createdAt   DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@index([documentId])
  @@index([productId])
}

// =============================================
// ERP: Pricing
// =============================================

model PriceList {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  prices SalePrice[]

  @@index([isActive])
}

model PurchasePrice {
  id         String    @id @default(cuid())
  productId  String
  supplierId String?
  price      Float
  currency   String    @default("RUB")
  validFrom  DateTime  @default(now())
  validTo    DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())

  product  Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Counterparty? @relation(fields: [supplierId], references: [id])

  @@index([productId, isActive, validFrom])
  @@index([supplierId])
}

model SalePrice {
  id          String    @id @default(cuid())
  productId   String
  priceListId String?
  price       Float
  currency    String    @default("RUB")
  validFrom   DateTime  @default(now())
  validTo     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  priceList PriceList? @relation(fields: [priceListId], references: [id])

  @@index([productId, priceListId, isActive, validFrom])
}

// =============================================
// E-COMMERCE: Enums
// =============================================

enum OrderStatus {
  pending      // Ожидает оплаты
  paid         // Оплачен
  processing   // Комплектуется
  shipped      // Отправлен
  delivered    // Доставлен
  cancelled    // Отменён
}

enum DeliveryType {
  pickup       // Самовывоз
  courier      // Курьерская доставка
}

enum EcomPaymentMethod {
  tochka       // Точка Банк
  cash         // При получении
}

enum EcomPaymentStatus {
  pending
  paid
  failed
  refunded
}

// =============================================
// E-COMMERCE: Customers
// =============================================

model Customer {
  id               String   @id @default(cuid())
  telegramId       String   @unique
  telegramUsername  String?
  name             String?
  phone            String?
  email            String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  orders    Order[]
  reviews   Review[]
  favorites Favorite[]
  addresses CustomerAddress[]
  cartItems CartItem[]

  @@index([isActive])
}

model CustomerAddress {
  id            String   @id @default(cuid())
  customerId    String
  label         String   @default("Дом")
  recipientName String
  phone         String
  city          String
  street        String
  building      String
  apartment     String?
  postalCode    String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@index([customerId])
}

// =============================================
// E-COMMERCE: Cart
// =============================================

model CartItem {
  id            String   @id @default(cuid())
  customerId    String
  productId     String
  variantId     String?
  quantity      Int      @default(1)
  priceSnapshot Float
  addedAt       DateTime @default(now())

  customer Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product         @relation(fields: [productId], references: [id])
  variant  ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([customerId, productId, variantId])
  @@index([customerId])
}

// =============================================
// E-COMMERCE: Orders
// =============================================

model Order {
  id                String            @id @default(cuid())
  orderNumber       String            @unique
  customerId        String
  status            OrderStatus       @default(pending)
  documentId        String?           @unique
  deliveryType      DeliveryType
  deliveryAddressId String?
  deliveryCost      Float             @default(0)
  totalAmount       Float
  paymentMethod     EcomPaymentMethod?
  paymentStatus     EcomPaymentStatus @default(pending)
  paymentExternalId String?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  paidAt            DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?

  customer        Customer         @relation(fields: [customerId], references: [id])
  deliveryAddress CustomerAddress? @relation(fields: [deliveryAddressId], references: [id])
  document        Document?        @relation(fields: [documentId], references: [id])
  items           OrderItem[]
  reviews         Review[]

  @@index([customerId, status])
  @@index([orderNumber])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  variantId String?
  quantity  Int
  price     Float
  total     Float
  createdAt DateTime @default(now())

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
}

// =============================================
// E-COMMERCE: Reviews
// =============================================

model Review {
  id                 String   @id @default(cuid())
  productId          String
  customerId         String
  orderId            String?
  rating             Int      // 1-5
  title              String?
  comment            String?
  isVerifiedPurchase Boolean  @default(false)
  isPublished        Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order    Order?   @relation(fields: [orderId], references: [id])

  @@index([productId, isPublished])
  @@index([customerId])
}

// =============================================
// E-COMMERCE: Favorites
// =============================================

model Favorite {
  id         String   @id @default(cuid())
  customerId String
  productId  String
  addedAt    DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
}

// =============================================
// E-COMMERCE: Promo Blocks
// =============================================

model PromoBlock {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String
  linkUrl   String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, order])
}

// =============================================
// E-COMMERCE: Order Counter
// =============================================

model OrderCounter {
  id         String @id @default(cuid())
  prefix     String @unique @default("ORD")
  lastNumber Int    @default(0)
}

// =============================================
// E-COMMERCE: CMS Pages
// =============================================

model StorePage {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  content        String   @db.Text
  seoTitle       String?
  seoDescription String?
  isPublished    Boolean  @default(false)
  sortOrder      Int      @default(0)
  showInFooter   Boolean  @default(true)
  showInHeader   Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isPublished, sortOrder])
  @@index([slug])
}

// =============================================
// INTEGRATIONS: External API connections
// =============================================

model Integration {
  id        String   @id @default(cuid())
  type      String   @unique  // "telegram", "1c", "moysklad", etc.
  name      String
  isEnabled Boolean  @default(true)
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, isEnabled])
}

// =============================================
// FINANCE: Categories & Payments
// =============================================

model FinanceCategory {
  id        String   @id @default(cuid())
  name      String
  type      String   // "income" | "expense"
  isSystem  Boolean  @default(false)
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[]

  @@index([type, isActive])
}

model PaymentCounter {
  id         String @id @default(cuid())
  prefix     String @unique @default("PAY")
  lastNumber Int    @default(0)
}

model Payment {
  id             String          @id @default(cuid())
  number         String          @unique
  type           String          // "income" | "expense"
  categoryId     String
  counterpartyId String?
  documentId     String?
  amount         Float
  paymentMethod  PaymentType
  date           DateTime        @default(now())
  description    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  category     FinanceCategory @relation(fields: [categoryId], references: [id])
  counterparty Counterparty?   @relation(fields: [counterpartyId], references: [id])
  document     Document?       @relation(fields: [documentId], references: [id])

  @@index([type, date])
  @@index([counterpartyId])
  @@index([documentId])
}
