{
  "name": "listopt-erp",
  "projectType": "application",
  "$schema": "node_modules/nx/schemas/project-schema.json",
  "sourceRoot": ".",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev --turbopack"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["prisma-generate"],
      "outputs": ["{projectRoot}/.next"],
      "options": {
        "command": "next build"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "next start"
      }
    },
    "prisma-generate": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/lib/generated/prisma"],
      "options": {
        "command": "prisma generate"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run tests/integration/api tests/unit --passWithNoTests"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint ."
      }
    }
  },
  "tags": ["type:app", "scope:erp"],
  "implicitDependencies": ["lib-shared"]
}
