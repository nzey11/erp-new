{
  "name": "listopt-erp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nx dev",
    "build": "nx build",
    "start": "next start -p 3000",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test --parallel=1",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:service": "vitest run --config vitest.service.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run",
    "test:watch": "vitest watch",
    "test:cov": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "affected:test": "nx affected -t test",
    "affected:build": "nx affected -t build",
    "affected:lint": "nx affected -t lint",
    "graph": "nx graph",
    "db:generate": "nx prisma-generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:headed": "npx playwright test --headed",
    "preview": "npm run build && npm start",
    "preview:check": "npm run lint && npm run test && npm run build",
    "typecheck": "tsc --noEmit",
    "check:fast": "npm run lint && npm run typecheck && npm run test:unit",
    "push": "pwsh scripts/push.ps1",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@prisma/client": "^7.4.1",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-heading": "^3.20.0",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pg": "^8.18.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.25.76",
    "prisma": "^7.4.1"
  },
  "devDependencies": {
    "@nx/eslint": "^22.5.2",
    "@nx/eslint-plugin": "^22.5.2",
    "@nx/js": "^22.5.2",
    "@nx/next": "^22.5.2",
    "@playwright/test": "^1.58.2",
    "@prisma/adapter-pg": "^7.4.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "nx": "^22.5.2",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
