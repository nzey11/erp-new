# ListOpt ERP — Environment Configuration
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/listopt_erp"

# ─────────────────────────────────────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────────────────────────────────────
# Session signing secret — MUST be changed in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-to-random-64-char-hex-string-in-production"

# ─────────────────────────────────────────────────────────────────────────────
# Server Port Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Local development (without Docker): uses port 3001
#   npm run dev
#
# Docker development: uses port 3000
#   docker-compose -f infra/docker/docker-compose.dev.yml up
#
# Production: uses port 3000
#   npm run start

# ─────────────────────────────────────────────────────────────────────────────
# Optional: Cookie Security
# ─────────────────────────────────────────────────────────────────────────────
# Set to "true" in production with HTTPS
# SECURE_COOKIES="false"
