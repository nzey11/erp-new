{
  "name": "lib-finance",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "lib/modules/finance",
  "projectType": "library",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint lib/modules/finance"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run tests/integration/finance --config tests/config/vitest.integration.config.ts --passWithNoTests"
      }
    }
  },
  "tags": ["type:lib", "scope:finance"],
  "implicitDependencies": ["lib-shared", "lib-accounting"]
}
